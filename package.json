{
  "name": "note-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "electron:start": "vite build && electron electron/main.cjs",
    "desktop:sync": "powershell -Command \"Copy-Item -Path 'dist/*' -Destination 'dist-desktop/NoteWeb-win32-x64/resources/app/dist' -Recurse -Force; Copy-Item -Path 'electron/main.cjs' -Destination 'dist-desktop/NoteWeb-win32-x64/resources/app/electron/main.cjs' -Force\"",
    "mobile:build": "vite build && npx cap sync",
    "git:status": "git status",
    "git:diff": "git diff",
    "git:add": "git add .",
    "git:commit": "git commit -m \"Implement chat seen indicators, mobile bottom nav swap, android camera/audio permissions, and Supabase RLS update policy\"",
    "git:push": "git push"
  },
  "dependencies": {
    "@capacitor/app": "^6.0.0",
    "@capacitor/core": "^6.2.0",
    "@capacitor/local-notifications": "^6.0.0",
    "@capgo/capacitor-updater": "^6.45.10",
    "@supabase/supabase-js": "^2.106.1",
    "framer-motion": "^12.39.0",
    "lucide-react": "^1.16.0",
    "pdfjs-dist": "^5.7.284",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1"
  },
  "devDependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/cli": "^6.2.0",
    "@capacitor/ios": "^6.2.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "electron": "^34.0.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "gh-pages": "^6.3.0",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
