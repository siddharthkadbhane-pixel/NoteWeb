# NoteWeb - Environment Variables Configuration Example
# Copy this file to .env and fill in your details.

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Google Gemini API Key for Summarization
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Security Whitelist: Comma-separated list of administrative emails/usernames allowed to have the 'admin' role
VITE_ADMIN_EMAILS=admin@college.edu,sid_phantom,siddharth

# Cloudinary Configuration
VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset_name
